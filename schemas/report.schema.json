{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/agent-context-lens/report.schema.json",
  "title": "Agent Context Lens repository report",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "repositoryRoot", "targetFile", "traces", "summary"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "repositoryRoot": {"type": "string"},
    "targetFile": {"type": "string"},
    "traces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agent", "targetFile", "sources", "includedSources", "estimatedTokens", "findings", "adapterVersion", "specificationDate", "caveats"],
        "properties": {
          "agent": {"enum": ["codex", "claude", "cursor", "copilot"]},
          "targetFile": {"type": "string"},
          "sources": {"type": "array"},
          "includedSources": {"type": "array"},
          "estimatedTokens": {"type": "integer", "minimum": 0},
          "findings": {"type": "array"},
          "adapterVersion": {"type": "string"},
          "specificationDate": {"type": "string"},
          "caveats": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["detectedFiles", "includedFiles", "totalFindings", "errors", "warnings"]
    }
  }
}
